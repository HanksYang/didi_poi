# 复制本文件为 .env，填入真实 Key
# cp .env.example .env

# 高德地图 Web服务 API Key
# 申请地址: https://lbs.amap.com/dev/key/app
AMAP_API_KEY=your_amap_web_service_key_here

# 火山引擎（字节跳动）API Key
# 申请地址: https://www.volcengine.com/
VOLC_API_KEY=your_volcano_api_key_here

# 路况数据源选择: amap / volcano（默认: amap）
TRAFFIC_PROVIDER=amap

# Anthropic Claude API Key（用于POI热度分析）
# 申请地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 目标城市（可选）: shanghai / beijing / guangzhou / shenzhen / chengdu
CITY=shanghai
